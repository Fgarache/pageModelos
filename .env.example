# Firebase Configuration
# For this public read-only frontend, only VITE_FIREBASE_DB_URL is required by default.
# The rest can stay empty unless you later add Auth, Storage SDK operations, or stricter project setup.
#
# IMPORTANT: These variables must be defined in Vercel Environment Variables
# Dashboard > Settings > Environment Variables
#
# Only VITE_FIREBASE_DB_URL is strictly required for production

# [REQUIRED] Firebase Realtime Database URL - Public read-only data source
VITE_FIREBASE_DB_URL=https://sitemodelgt-default-rtdb.firebaseio.com

# [OPTIONAL] Firebase API Key - Leave empty if Auth not implemented
VITE_FIREBASE_API_KEY=

# [OPTIONAL] Firebase Auth Domain - Leave empty if Auth not implemented
VITE_FIREBASE_AUTH_DOMAIN=

# [OPTIONAL] Firebase Project ID - Leave empty if Auth not implemented
VITE_FIREBASE_PROJECT_ID=
